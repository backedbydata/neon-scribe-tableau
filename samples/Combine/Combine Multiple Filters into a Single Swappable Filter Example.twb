      <column caption='Applications with Prior Bachelor&apos;s+' datatype='integer' default-format='n#,##0;-#,##0' name='[Applications Under 30 (copy)_789818813287616516]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF CONTAINS([Prior Edu],&quot;degree&quot;)&#13;&#10;THEN [Application Number]&#13;&#10;END)' />
      </column>
      <column caption='Applications Female' datatype='integer' default-format='n#,##0;-#,##0' name='[Applications Under 30 (copy)_789818813288316934]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Sex] = &quot;Female&quot;&#13;&#10;THEN [Application Number]&#13;&#10;END)' />
      </column>
      <column caption='Applications SOC' datatype='integer' default-format='n#,##0;-#,##0' name='[Applications Under 30 (copy)_789818813288738824]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Students of Color]&#13;&#10;THEN [Application Number]&#13;&#10;END)' />
      </column>
      <column caption='Applications with Prior Bachelor&apos;s+ %' datatype='real' default-format='p0%' name='[Applications Under 30% (copy)_789818813287768069]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Applications Under 30 (copy)_789818813287616516] / [Calculation_789818813285937153]' />
      </column>
      <column caption='Applications Female %' datatype='real' default-format='p0%' name='[Applications Under 30% (copy)_789818813288398855]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Applications Under 30 (copy)_789818813288316934] / [Calculation_789818813285937153]' />
      </column>
      <column caption='Applications SOC %' datatype='real' default-format='p0%' name='[Applications Under 30% (copy)_789818813288800265]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Applications Under 30 (copy)_789818813288738824] / [Calculation_789818813285937153]' />
      </column>
      <column caption='Additional Filter Field' datatype='string' name='[Calculation_1959347341554843648]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN 1 THEN [Age Group]&#13;&#10;WHEN 2 THEN [Prior Edu]&#13;&#10;WHEN 3 THEN [First Gen]&#13;&#10;WHEN 4 THEN [Full-Time/Part-Time]&#13;&#10;WHEN 5 THEN [Workforce Funding]&#13;&#10;WHEN 6 THEN [Worker Retraining]&#13;&#10;WHEN 7 THEN [Vet Status]&#13;&#10;WHEN 8 THEN [Running Start]&#13;&#10;WHEN 9 THEN [Pell Grant]&#13;&#10;WHEN 10 THEN [Econ Disad]&#13;&#10;WHEN 11 THEN [Disability]&#13;&#10;END' />
      </column>
      <column caption='Application Count' datatype='integer' default-format='n#,##0;-#,##0' name='[Calculation_789818813285937153]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Application Number])' />
      </column>
      <column caption='Applications Under 30' datatype='integer' default-format='n#,##0;-#,##0' name='[Calculation_789818813286748162]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Age Group] = &quot;&lt;18&quot;&#13;&#10;OR INT(LEFT([Age Group],2))&lt;30&#13;&#10;THEN [Application Number]&#13;&#10;END)' />
      </column>
      <column caption='Applications Under 30%' datatype='real' default-format='p0%' name='[Calculation_789818813286936579]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_789818813286748162] / [Calculation_789818813285937153]' />
      </column>
      <column caption='Applications By' datatype='string' name='[Calculation_789818813289242634]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;WHEN 1 THEN &quot;Total&quot;&#13;&#10;WHEN 2 THEN [Race Name]&#13;&#10;WHEN 3 THEN [Sex]&#13;&#10;WHEN 4 THEN [Age Group]&#13;&#10;END' />
