            <column datatype='date' name='[Application Submit Date]' role='dimension' type='ordinal' />
            <column caption='Additional Filter Field' datatype='string' name='[Calculation_1959347341554843648]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN 1 THEN [Age Group]&#13;&#10;WHEN 2 THEN [Prior Edu]&#13;&#10;WHEN 3 THEN [First Gen]&#13;&#10;WHEN 4 THEN [Full-Time/Part-Time]&#13;&#10;WHEN 5 THEN [Workforce Funding]&#13;&#10;WHEN 6 THEN [Worker Retraining]&#13;&#10;WHEN 7 THEN [Vet Status]&#13;&#10;WHEN 8 THEN [Running Start]&#13;&#10;WHEN 9 THEN [Pell Grant]&#13;&#10;WHEN 10 THEN [Econ Disad]&#13;&#10;WHEN 11 THEN [Disability]&#13;&#10;END' />
            </column>
            <column caption='Application Count' datatype='integer' default-format='n#,##0;-#,##0' name='[Calculation_789818813285937153]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD([Application Number])' />
            </column>
            <column caption='Applications Under 30' datatype='integer' default-format='n#,##0;-#,##0' name='[Calculation_789818813286748162]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='COUNTD(IF [Age Group] = &quot;&lt;18&quot;&#13;&#10;OR INT(LEFT([Age Group],2))&lt;30&#13;&#10;THEN [Application Number]&#13;&#10;END)' />
