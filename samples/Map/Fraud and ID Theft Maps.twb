    <worksheet name='State Age-Table'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#1b1b1b' fontname='Franklin Gothic Demi'>Fraud Reports and Losses</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='rtp_ComplaintCountByStateAge' name='federated.07pwzvg0nhjfkv1esmu4f0583vyu' />
          </datasources>
          <datasource-dependencies datasource='federated.07pwzvg0nhjfkv1esmu4f0583vyu'>
            <column caption='$ State &amp; Age Median Logic' datatype='real' default-format='c&quot;$&quot;#,##0;(&quot;$&quot;#,##0)' name='[Calculation_1385419877190746112]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='//$ State &amp; Age Median Logic&#13;&#10;IIF(&#13;&#10; // single quarter selected --&gt; quarter&#13;&#10; COUNTD([Quarter]) = 1&#13;&#10; ,ROUND(MIN([Calculation_1385419877191495689]))&#13;&#10;   // all quarters selected --&gt; annual&#13;&#10;   ,IIF([Calculation_1385419877191569419] OR [Calculation_1385419877191589900]&#13;&#10;   ,ROUND(MIN([Calculation_1385419877191524362]))&#13;&#10;      // do not display median         &#13;&#10;      ,0))' />
            </column>
            <column caption='# State &amp; Age Fraud' datatype='integer' name='[Calculation_1385419877191307270]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='//# State &amp; Age Fraud&#13;&#10;{FIXED [StateName],[Year],[Quarter],[Fraud],[Consumer_Age] : MIN([State Fraud/Other Count Age]) }&#13;&#10;' />
            </column>
            <column caption='# State &amp; Age Rpt Loss' datatype='real' name='[Calculation_1385419877191430152]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='//# State &amp; Age Rpt Loss&#13;&#10;{ FIXED [StateName],[Year],[Quarter],[Fraud],[Consumer_Age] : MIN([Reporting Loss by Type Quarter Age]) }&#13;&#10;' />
            </column>
            <column caption='$ State &amp; Age Med Qtr' datatype='real' name='[Calculation_1385419877191495689]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='//$ State &amp; Age Med Qtr&#13;&#10;{ FIXED [StateName],[Year],[Quarter],[Fraud],[Consumer_Age] : MIN([state_median_quarterly age]) }&#13;&#10;' />
            </column>
            <column caption='$ State &amp; Age Med Yr' datatype='real' name='[Calculation_1385419877191524362]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='//$ State &amp; Age Med Yr&#13;&#10;{ FIXED [StateName],[Year],[Quarter],[Fraud],[Consumer_Age] : MIN([state_median_year_age]) }&#13;&#10;' />
            </column>
            <column caption='Median Logic Count 1' datatype='boolean' name='[Calculation_1385419877191569419]' role='measure' type='nominal'>
              <calculation class='tableau' formula='//Median Logic Count 1&#13;&#10;// 4 quarters are selected&#13;&#10;COUNTD([Quarter]) = 4' />
            </column>
            <column caption='Median Logic Count 2' datatype='boolean' name='[Calculation_1385419877191589900]' role='measure' type='nominal'>
              <calculation class='tableau' formula='//Median Logic Count 2&#13;&#10;// all quarters of current year are selected (ie YTD)&#13;&#10;MAX({FIXED : MAX([Year])}) = MAX([Year]) AND MAX({FIXED [Year] : MAX([Quarter])}) = COUNTD([Quarter])' />
            </column>
            <column caption='$ State &amp; Age Ttl Loss' datatype='real' default-format='c&quot;$&quot;#,##0;(&quot;$&quot;#,##0)' name='[Calculation_1385419877191630861]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='//$ State &amp; Age Ttl Loss&#13;&#10;{ FIXED [StateName],[Year],[Quarter],[Fraud],[Consumer_Age] : MIN([Total Losses Age]) }&#13;&#10;' />
            </column>
            <column caption='SUM([# State &amp; Age Rpt Loss])/SUM([# State &amp; Age Fraud])' datatype='real' name='[Calculation_1385419877192593422]' role='measure' type='quantitative' user:unnamed='Sheet 132'>
              <calculation class='tableau' formula='SUM([Calculation_1385419877191430152])/SUM([Calculation_1385419877191307270])' />
            </column>
