        <calculation class='tableau' formula='&apos;Top 5 Fraud Categories&apos;' />
      </column>
      <column caption='Title Other' datatype='string' name='[Calculation_2313724312040910852]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&apos;Top 5 Other Categories&apos;' />
      </column>
      <column caption='Title Quarter' datatype='string' name='[Calculation_2630946616814346243]' role='measure' type='nominal'>
        <calculation class='tableau' formula='//If the fixed max year = the max year (2018) AND the fixed max quarter = number of quarters AND there are less than 4  ===== YTD&#13;&#10;IIF(max({fixed: max([Year])}) = max([Year]) AND max({FIXED  [Year]:max([Quarter])}) == countd([Quarter]) AND countd([Quarter])&lt;4,&apos; YTD&apos;,&#13;&#10;&#13;&#10;IIF((COUNTD([Quarter])=4),&apos;&apos;,&#13;&#10;IIF((COUNTD([Quarter])=1 AND str(min([Quarter])) = &apos;1&apos;), &apos;, Quarter: 1&apos;,&#13;&#10;IIF((COUNTD([Quarter])=1 AND str(min([Quarter])) = &apos;2&apos;), &apos;, Quarter: 2&apos;,&#13;&#10;IIF((COUNTD([Quarter])=1 AND str(min([Quarter])) = &apos;3&apos;), &apos;, Quarter: 3&apos;,&#13;&#10;IIF((COUNTD([Quarter])=1 AND str(min([Quarter])) = &apos;4&apos;), &apos;, Quarter: 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;2&apos;), &apos;, Quarters: 1 &amp; 2&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;3&apos;), &apos;, Quarters: 1 &amp; 3&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;4&apos;), &apos;, Quarters: 1 &amp; 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;2&apos; AND str(max([Quarter])) = &apos;3&apos;), &apos;, Quarters: 2 &amp; 3&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;2&apos; AND str(max([Quarter])) = &apos;4&apos;), &apos;, Quarters: 2 &amp; 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;3&apos; AND str(max([Quarter])) = &apos;4&apos;), &apos;, Quarters: 3 &amp; 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=3 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;3&apos;), &apos;, Quarters: 1, 2, 3&apos;,&#13;&#10;IIF((COUNTD([Quarter])=3 AND str(min([Quarter])) = &apos;2&apos; AND str(max([Quarter])) = &apos;4&apos;), &apos;, Quarters: 2, 3, 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=3 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;4&apos; AND str(median([Quarter])) = &apos;2&apos;), &apos;, Quarters: 1, 2, 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=3 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;4&apos; AND str(median([Quarter])) = &apos;3&apos;), &apos;, Quarters: 1, 3, 4&apos;,&#13;&#10;&#13;&#10;&apos;ERROR&apos;))))))))))))))))' />
      </column>
      <column caption='MSA Geo' datatype='string' name='[Calculation_2630946616828514310]' role='dimension' semantic-role='[CMSA].[Name]' type='nominal'>
        <calculation class='tableau' formula='LEFT([MSA],LEN([MSA])-30)' />
      </column>
      <column caption='Instructions' datatype='string' name='[Calculation_2630946616871170059]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&apos;&apos;' />
      </column>
      <column caption='Reports per 100K Population' datatype='real' default-format='n#,##0;-#,##0' name='[Calculation_2675419658521985025]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Total Reports])/MIN([MSA Pop])*100000' />
      </column>
      <column caption='Title MSA F&amp;O' datatype='string' name='[Calculation_2965338889582759964 1]' role='measure' type='nominal'>
        <calculation class='tableau' formula='CASE TOTAL(COUNTD([Calculation_2630946616828514310]))&#13;&#10;  WHEN [Parameters].[LPC View (copy)] THEN &apos;All Fraud and Other Reports&apos;&#13;&#10;  WHEN 1 THEN MIN([Calculation_2630946616828514310])+&apos; Metro Area&apos;&#13;&#10;  ELSE STR(COUNTD([Calculation_2630946616828514310]))+&apos; Metro Areas Selected&apos;&#13;&#10;  END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Title MSA IDT' datatype='string' name='[Calculation_2965338889582759964]' role='measure' type='nominal'>
        <calculation class='tableau' formula='CASE TOTAL(COUNTD([Calculation_2630946616828514310]))&#13;&#10;  WHEN [Parameters].[LPC View (copy)] THEN &apos;All Identity Theft Reports&apos;&#13;&#10;  WHEN 1 THEN MIN([Calculation_2630946616828514310])+&apos; Metro Area&apos;&#13;&#10;  ELSE STR(COUNTD([Calculation_2630946616828514310]))+&apos; Metro Areas Selected&apos;&#13;&#10;  END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Fixed MSA Pop' datatype='real' name='[Calculation_6150509743611478018]' role='measure' type='quantitative'>
