    <worksheet name='FxS-Whiteout'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Æ&#10;</run>
            <run fontname='Franklin Gothic Book' fontsize='9'>*Median losses available only for a single year, quarter, or state.</run>
            <run>Æ&#10;&#10;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='rtp_ComplaintCountByState' name='federated.1xlz3n2061m65e13vr58o06l9av8' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='State View' datatype='string' name='[MSA View (copy)]' param-domain-type='list' role='measure' type='nominal' value='&quot;Map&quot;'>
              <calculation class='tableau' formula='&quot;Map&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1xlz3n2061m65e13vr58o06l9av8'>
            <column caption='Fixed Overall Median Yr' datatype='real' name='[Calculation_1102537487927623680]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [Year],[Report Type]: MIN([Overall Median Losses Yr])}' />
            </column>
            <column caption='State View Selection' datatype='string' name='[Calculation_1597651976229257216]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Parameters].[MSA View (copy)]' />
            </column>
            <column caption='Fixed Overall Median Qtr' datatype='real' name='[Calculation_2425188444313452572 1]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [Year],[Quarter],[Report Type]: MIN([Overall Median Losses Qtr])}' />
            </column>
            <column caption='Fixed State Median Qtr' datatype='real' name='[Calculation_2425188444313452572]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED [Year], [Quarter],[StateName], [Report Type]: min([state_median_quarterly])}' />
            </column>
            <column caption='Whiteout' datatype='string' name='[Calculation_3030359646159241217]' role='measure' type='nominal'>
              <calculation class='tableau' formula='If [Calculation_6241426172937134085]=&apos;REMOVE&apos; THEN &apos;*Median losses available only for a single year, quarter, or state.&apos; ELSE &apos;REMOVE&apos; END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Fixed State Median Yr' datatype='real' name='[Calculation_461056059378786304]' role='measure' type='quantitative'>
