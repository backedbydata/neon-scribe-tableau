      </column>
      <column caption='Whiteout' datatype='string' name='[Calculation_3030359646159241217]' role='measure' type='nominal'>
        <calculation class='tableau' formula='If [Calculation_6241426172937134085]=&apos;REMOVE&apos; THEN &apos;*Median losses available only for a single year, quarter, or state.&apos; ELSE &apos;REMOVE&apos; END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Reports per 100K-calc' datatype='real' default-format='n#,##0;-#,##0' name='[Calculation_3460171931540054016]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Qtr Category Complaint Count])/MIN([State Pop])*100000' />
      </column>
      <column caption='Reports per 100K-F&amp;O together' datatype='real' name='[Calculation_3843822308786319360]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_3843822308793171969])/AVG([State Pop])*100000' />
      </column>
      <column caption='Fixed State F&amp;O' datatype='real' name='[Calculation_3843822308793171969]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='//using MAX 0 because IDT=0 in Paul&apos;s report&#13;&#10;{ FIXED [Year], [Quarter], [StateName] : MAX([State Total Reports Quarter]) }' />
      </column>
      <column caption='Fixed State IDT' datatype='real' name='[Calculation_3843822308799361026]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Year], [Quarter], [StateName] : MAX(IF [Category] = &apos;IDT&apos; THEN [Qtr Category Complaint Count Total] ELSE 0 END) }' />
      </column>
      <column caption='Date Stamp' datatype='string' default-format='*mmmm dd, yyyy' name='[Calculation_4494592477086498817]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&apos;December 11, 2025&apos;+CHAR(10)+&apos;(data as of September 30, 2025)&apos;' />
      </column>
      <column caption='Fixed State Median Yr' datatype='real' name='[Calculation_461056059378786304]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Year],[Quarter],[Report Type],[StateName]: min([state_median_year])}' />
      </column>
      <column caption='Instructions' datatype='string' name='[Calculation_4840243746760970240]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;i&quot;' />
      </column>
      <column caption='Median Logic (1)' datatype='string' name='[Calculation_6241426172937134085 1]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IIF(&#13;&#10; // no state selections, single quarter selected --&gt; national quarter&#13;&#10; TOTAL(COUNTD([StateName])) = 52 AND COUNTD([Quarter]) = 1&#13;&#10; ,&apos;$&apos;+STR(ROUND(MIN([Calculation_2425188444313452572 1])))&#13;&#10;   // no state selections, all quarters selected --&gt; national annual&#13;&#10;   ,IIF(TOTAL(COUNTD([StateName])) = 52 AND (COUNTD([Quarter]) = 4 OR (MAX({FIXED : MAX([Year])}) = MAX([Year]) AND MAX({FIXED [Year] : MAX([Quarter])}) = COUNTD([Quarter])))&#13;&#10;   ,&apos;$&apos;+STR(ROUND(MIN([Calculation_1102537487927623680])))&#13;&#10;      // single state selected, single quarter selected --&gt; state quarter&#13;&#10;      ,IIF(TOTAL(COUNTD([StateName])) = 1 AND COUNTD([Quarter]) = 1&#13;&#10;      ,&apos;$&apos;+STR(ROUND(MIN([Calculation_2425188444313452572])))&#13;&#10;         // single state selected, all quarters selected --&gt; state annual&#13;&#10;         ,IIF(TOTAL(COUNTD([StateName])) = 1 AND (COUNTD([Quarter]) = 4 OR (MAX({FIXED : MAX([Year])}) = MAX([Year]) AND MAX({FIXED [Year] : MAX([Quarter])}) = COUNTD([Quarter])))&#13;&#10;         ,&apos;$&apos;+STR(ROUND(MIN([Calculation_461056059378786304])))&#13;&#10;           // do not display median         &#13;&#10;           ,&apos;REMOVE&apos;))))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Median Logic' datatype='string' name='[Calculation_6241426172937134085]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IIF(&#13;&#10; // no state selections, single quarter selected --&gt; national quarter&#13;&#10; TOTAL(COUNTD([StateName])) = 52 AND COUNTD([Quarter]) = 1&#13;&#10; ,&apos;$&apos;+STR(ROUND(MIN([Calculation_2425188444313452572 1])))&#13;&#10;   // no state selections, all quarters selected --&gt; national annual&#13;&#10;   ,IIF(TOTAL(COUNTD([StateName])) = 52 AND (COUNTD([Quarter]) = 4 OR (MAX({FIXED : MAX([Year])}) = MAX([Year]) AND MAX({FIXED [Year] : MAX([Quarter])}) = COUNTD([Quarter])))&#13;&#10;   ,&apos;$&apos;+STR(ROUND(MIN([Calculation_1102537487927623680])))&#13;&#10;      // single state selected, single quarter selected --&gt; state quarter&#13;&#10;      ,IIF(TOTAL(COUNTD([StateName])) = 1 AND COUNTD([Quarter]) = 1&#13;&#10;      ,&apos;$&apos;+STR(ROUND(MIN([Calculation_2425188444313452572])))&#13;&#10;         // single state selected, all quarters selected --&gt; state annual&#13;&#10;         ,IIF(TOTAL(COUNTD([StateName])) = 1 AND (COUNTD([Quarter]) = 4 OR (MAX({FIXED : MAX([Year])}) = MAX([Year]) AND MAX({FIXED [Year] : MAX([Quarter])}) = COUNTD([Quarter])))&#13;&#10;         ,&apos;$&apos;+STR(ROUND(MIN([Calculation_461056059378786304])))&#13;&#10;           // do not display median         &#13;&#10;           ,&apos;REMOVE&apos;))))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Year-Qtr' datatype='string' name='[Calculation_744501362348310528]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='str(Year)+&quot; Q&quot; +str([Quarter])' />
      </column>
      <column datatype='string' name='[Category]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;Credit Bureaus, Information Furnishers and Report Users&quot;' value='Credit Bureaus, Info Furnishers and Report Users' />
          <alias key='&quot;IDT&quot;' value='Identity Theft' />
          <alias key='&quot;Impostor Scams&quot;' value='Imposter Scams' />
        </aliases>
      </column>
      <column caption='Fixed State Cat F only' datatype='real' name='[Fixed State Cat F&amp;O together (copy)_4224939448085749761]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Year], [Quarter], [StateName], [Fraud], [Category] : MIN([Qtr Category Complaint Count Total]) }' />
      </column>
      <column datatype='integer' name='[Number of Records]' role='measure' type='quantitative' user:auto-column='numrec'>
        <calculation class='tableau' formula='1' />
      </column>
      <column datatype='integer' default-format='n#,##0;-#,##0' name='[Qtr Category Complaint Count]' role='measure' type='quantitative' />
      <column aggregation='Sum' datatype='integer' name='[Quarter]' role='dimension' type='quantitative' />
      <column caption='Rank-F cat only' datatype='integer' name='[Rank-F&amp;O cat together (copy)_4224939448085655552]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([Fixed State Cat F&amp;O together (copy)_4224939448085749761]),&apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column datatype='string' name='[Report Type]' role='dimension' type='nominal' />
      <column datatype='integer' datatype-customized='true' name='[Reports per 100K Population F&amp;O Quarter]' role='measure' type='quantitative' />
      <column datatype='integer' datatype-customized='true' name='[Reports per 100K Population F&amp;O Year]' role='measure' type='quantitative' />
      <column caption='State Name' datatype='string' name='[StateName]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
      <column caption='Title State IDT' datatype='string' name='[Title All (1) (copy) 1]' role='measure' type='nominal'>
        <calculation class='tableau' formula='CASE TOTAL(COUNTD([StateName]))&#13;&#10;  WHEN 52 THEN &apos;All Identity Theft Reports&apos;&#13;&#10;  WHEN 1 THEN MIN([StateName])&#13;&#10;  ELSE STR(COUNTD([StateName]))+&apos; States Selected&apos;&#13;&#10;  END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Title State All' datatype='string' name='[Title All (1) (copy)]' role='measure' type='nominal'>
        <calculation class='tableau' formula='CASE TOTAL(COUNTD([StateName]))&#13;&#10;  WHEN 52 THEN &apos;All Sentinel Reports&apos;&#13;&#10;  WHEN 1 THEN MIN([StateName])&#13;&#10;  ELSE STR(COUNTD([StateName]))+&apos; States Selected&apos;&#13;&#10;  END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Title State F&amp;O' datatype='string' name='[Title State (copy)_4224939448109551618]' role='measure' type='nominal'>
        <calculation class='tableau' formula='CASE TOTAL(COUNTD([StateName]))&#13;&#10;  WHEN 52 THEN &apos;All Fraud and Other Reports&apos;&#13;&#10;  WHEN 1 THEN MIN([StateName])&#13;&#10;  ELSE STR(COUNTD([StateName]))+&apos; States Selected&apos;&#13;&#10;  END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Title Quarter' datatype='string' name='[Title Year (copy)]' role='measure' type='nominal'>
        <calculation class='tableau' formula='//If the fixed max year = the max year (2018) AND the fixed max quarter = number of quarters AND there are less than 4  ===== YTD&#13;&#10;IIF(max({fixed: max([Year])}) = max([Year]) AND max({FIXED  [Year]:max([Quarter])}) == countd([Quarter]) AND countd([Quarter])&lt;4,&apos; YTD&apos;,&#13;&#10;&#13;&#10;IIF((COUNTD([Quarter])=4),&apos;&apos;,&#13;&#10;IIF((COUNTD([Quarter])=1 AND str(min([Quarter])) = &apos;1&apos;), &apos;, Quarter: 1&apos;,&#13;&#10;IIF((COUNTD([Quarter])=1 AND str(min([Quarter])) = &apos;2&apos;), &apos;, Quarter: 2&apos;,&#13;&#10;IIF((COUNTD([Quarter])=1 AND str(min([Quarter])) = &apos;3&apos;), &apos;, Quarter: 3&apos;,&#13;&#10;IIF((COUNTD([Quarter])=1 AND str(min([Quarter])) = &apos;4&apos;), &apos;, Quarter: 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;2&apos;), &apos;, Quarters: 1 &amp; 2&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;3&apos;), &apos;, Quarters: 1 &amp; 3&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;4&apos;), &apos;, Quarters: 1 &amp; 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;2&apos; AND str(max([Quarter])) = &apos;3&apos;), &apos;, Quarters: 2 &amp; 3&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;2&apos; AND str(max([Quarter])) = &apos;4&apos;), &apos;, Quarters: 2 &amp; 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;3&apos; AND str(max([Quarter])) = &apos;4&apos;), &apos;, Quarters: 3 &amp; 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=3 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;3&apos;), &apos;, Quarters: 1, 2, 3&apos;,&#13;&#10;IIF((COUNTD([Quarter])=3 AND str(min([Quarter])) = &apos;2&apos; AND str(max([Quarter])) = &apos;4&apos;), &apos;, Quarters: 2, 3, 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=3 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;4&apos; AND str(median([Quarter])) = &apos;2&apos;), &apos;, Quarters: 1, 2, 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=3 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;4&apos; AND str(median([Quarter])) = &apos;3&apos;), &apos;, Quarters: 1, 3, 4&apos;,&#13;&#10;&#13;&#10;&apos;ERROR&apos;))))))))))))))))' />
      </column>
