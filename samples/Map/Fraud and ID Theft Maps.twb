      <column caption='SxS-Footnote' datatype='string' name='[Calculation_2392537306841387013]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IIF([Parameters].[MSA View (copy)] = &apos;Map&apos;,&#13;&#10;&apos;State population estimates are based on U.S. Census population estimates for &apos;+[Parameters].[LPC View (copy)_1344606019964723200]+&apos;.&apos;,&#13;&#10;&apos;The District of Columbia and Puerto Rico are included in the table but are not ranked. State rankings are based on the number of reports per 100,000 population. Population estimates are based on U.S. Census population estimates for &apos;+[Parameters].[LPC View (copy)_1344606019964723200]+&apos;.&apos;)' />
      </column>
      <column caption='Rank' datatype='integer' name='[Calculation_543246712742584320]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([# of Reports TheftType QTR]),&apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Fixed State IDT Reports' datatype='integer' name='[Calculation_543246712794894352]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Year],[Quarter],[StateName] : MIN([QTR State Count]) }' />
      </column>
      <column caption='Reports per 100K' datatype='real' default-format='n#,##0;-#,##0' name='[Calculation_543246712794963985]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_543246712794894352])/AVG([State Pop])*100000' />
