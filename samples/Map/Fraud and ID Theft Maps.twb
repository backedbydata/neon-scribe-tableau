            <column caption='_PSC Title' datatype='string' name='[Calculation_1385419877190955009]' role='measure' type='nominal'>
              <calculation class='tableau' formula='//_PSC Title&#13;&#10;IF WINDOW_MAX([Calculation_1507298542393667584]) = 9 THEN &apos;All&apos;&#13;&#10;ELSEIF COUNTD([Consumer_Age]) &gt; 1 THEN &apos;Selected Age Ranges&apos;&#13;&#10;ELSE &apos;Aged &apos;+ATTR([Consumer_Age])&#13;&#10;END'>
                <table-calc ordering-type='Rows' />
