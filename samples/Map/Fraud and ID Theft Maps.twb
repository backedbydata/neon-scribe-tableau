            <column caption='_Footnote Date' datatype='string' name='[Calculation_1385419877191069699]' role='measure' type='nominal'>
              <calculation class='tableau' formula='//_Footnote Date&#13;&#10;//If the fixed max year = the max year AND the fixed max quarter = number of quarters AND there are less than 4  ===== YTD&#13;&#10;IIF(max({fixed: max([Year])}) = max([Year]) AND max({FIXED  [Year]:max([Quarter])}) == countd([Quarter]) AND countd([Quarter])&lt;4,&apos; YTD&apos;,&#13;&#10;IIF((COUNTD([Quarter])=4),&apos;&apos;,&#13;&#10;IIF((COUNTD([Quarter])=1 AND str(min([Quarter])) = &apos;1&apos;), &apos; Q1&apos;,&#13;&#10;IIF((COUNTD([Quarter])=1 AND str(min([Quarter])) = &apos;2&apos;), &apos; Q2&apos;,&#13;&#10;IIF((COUNTD([Quarter])=1 AND str(min([Quarter])) = &apos;3&apos;), &apos; Q3&apos;,&#13;&#10;IIF((COUNTD([Quarter])=1 AND str(min([Quarter])) = &apos;4&apos;), &apos; Q4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;2&apos;), &apos;, Quarters: 1 &amp; 2&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;3&apos;), &apos;, Quarters: 1 &amp; 3&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;4&apos;), &apos;, Quarters: 1 &amp; 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;2&apos; AND str(max([Quarter])) = &apos;3&apos;), &apos;, Quarters: 2 &amp; 3&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;2&apos; AND str(max([Quarter])) = &apos;4&apos;), &apos;, Quarters: 2 &amp; 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;3&apos; AND str(max([Quarter])) = &apos;4&apos;), &apos;, Quarters: 3 &amp; 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=3 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;3&apos;), &apos;, Quarters: 1, 2, 3&apos;,&#13;&#10;IIF((COUNTD([Quarter])=3 AND str(min([Quarter])) = &apos;2&apos; AND str(max([Quarter])) = &apos;4&apos;), &apos;, Quarters: 2, 3, 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=3 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;4&apos; AND str(median([Quarter])) = &apos;2&apos;), &apos;, Quarters: 1, 2, 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=3 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;4&apos; AND str(median([Quarter])) = &apos;3&apos;), &apos;, Quarters: 1, 3, 4&apos;,&#13;&#10;&apos;ERROR&apos;))))))))))))))))' />
            </column>
            <column caption='# State &amp; Age Rpt Age' datatype='integer' name='[Calculation_1385419877191364615]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='//# State &amp; Age Rpt Age&#13;&#10;{ FIXED [StateName],[Year],[Quarter],[Fraud],[Consumer_Age] : MIN([State Fraud/Other Count Age]) }&#13;&#10;' />
            </column>
            <column caption='# State Fraud' datatype='integer' name='[Calculation_1385419877202632719]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [StateName],[Year],[Quarter],[Fraud] : MIN([state_fraud_count]) }' />
            </column>
            <column caption='% with age' datatype='real' default-format='p0.0%' name='[Calculation_1385419877209903122]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_1385419877191364615])/SUM([Calculation_1385419877202632719])' />
            </column>
            <column caption='Consumer Age' datatype='string' name='[Consumer_Age]' role='dimension' type='nominal' />
            <column datatype='string' name='[Fraud]' role='dimension' type='nominal' />
            <column datatype='integer' name='[Quarter]' role='dimension' type='quantitative' />
