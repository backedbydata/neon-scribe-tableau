              <calculation class='tableau' formula='&quot;Map&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.18nr4jq0f6jidv17ptch70aram23'>
            <column datatype='integer' name='[# of Reports by Type]' role='measure' type='quantitative' />
            <column caption='State View Selection' datatype='string' name='[Calculation_1597651976230850562]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Parameters].[MSA View (copy)]' />
            </column>
            <column caption='Action' datatype='string' name='[Calculation_1834372491014090755]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&apos;&apos;' />
            </column>
            <column caption='Fixed # of Reports by Type Qtr' datatype='integer' name='[Calculation_2058426550066049030]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [Year],[Quarter],[Report Type],[Military]:min([# of Reports by Type])}' />
            </column>
            <column caption='Category-remove' datatype='string' name='[Category (copy)]' role='dimension' type='nominal'>
