            </column>
            <column caption='# State &amp; Age &amp; PSC' datatype='integer' name='[Calculation_1385419877191122948]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='//# State &amp; Age &amp; Cat&#13;&#10;{ FIXED [StateName],[Consumer_Age],[Fraud],[Year],[Quarter],[ProductProductCodeDesc] : MIN([Qtr ProductProductCodeDesc Complaint Count Age]) }' />
