    <worksheet name='AxS-Median Box'>
      <table>
        <view>
          <datasources>
            <datasource caption='rtp_ComplaintCountByState' name='federated.1xlz3n2061m65e13vr58o06l9av8' />
          </datasources>
          <datasource-dependencies datasource='federated.1xlz3n2061m65e13vr58o06l9av8'>
            <column caption='Fixed Overall Median Yr' datatype='real' name='[Calculation_1102537487927623680]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [Year],[Report Type]: MIN([Overall Median Losses Yr])}' />
            </column>
            <column caption='Fixed Overall Median Qtr' datatype='real' name='[Calculation_2425188444313452572 1]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [Year],[Quarter],[Report Type]: MIN([Overall Median Losses Qtr])}' />
            </column>
            <column caption='Fixed State Median Qtr' datatype='real' name='[Calculation_2425188444313452572]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED [Year], [Quarter],[StateName], [Report Type]: min([state_median_quarterly])}' />
            </column>
            <column caption='Fixed State Median Yr' datatype='real' name='[Calculation_461056059378786304]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [Year],[Quarter],[Report Type],[StateName]: min([state_median_year])}' />
            </column>
            <column caption='Median Logic' datatype='string' name='[Calculation_6241426172937134085]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IIF(&#13;&#10; // no state selections, single quarter selected --&gt; national quarter&#13;&#10; TOTAL(COUNTD([StateName])) = 52 AND COUNTD([Quarter]) = 1&#13;&#10; ,&apos;$&apos;+STR(ROUND(MIN([Calculation_2425188444313452572 1])))&#13;&#10;   // no state selections, all quarters selected --&gt; national annual&#13;&#10;   ,IIF(TOTAL(COUNTD([StateName])) = 52 AND (COUNTD([Quarter]) = 4 OR (MAX({FIXED : MAX([Year])}) = MAX([Year]) AND MAX({FIXED [Year] : MAX([Quarter])}) = COUNTD([Quarter])))&#13;&#10;   ,&apos;$&apos;+STR(ROUND(MIN([Calculation_1102537487927623680])))&#13;&#10;      // single state selected, single quarter selected --&gt; state quarter&#13;&#10;      ,IIF(TOTAL(COUNTD([StateName])) = 1 AND COUNTD([Quarter]) = 1&#13;&#10;      ,&apos;$&apos;+STR(ROUND(MIN([Calculation_2425188444313452572])))&#13;&#10;         // single state selected, all quarters selected --&gt; state annual&#13;&#10;         ,IIF(TOTAL(COUNTD([StateName])) = 1 AND (COUNTD([Quarter]) = 4 OR (MAX({FIXED : MAX([Year])}) = MAX([Year]) AND MAX({FIXED [Year] : MAX([Quarter])}) = COUNTD([Quarter])))&#13;&#10;         ,&apos;$&apos;+STR(ROUND(MIN([Calculation_461056059378786304])))&#13;&#10;           // do not display median         &#13;&#10;           ,&apos;REMOVE&apos;))))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column datatype='string' name='[Fraud]' role='dimension' type='nominal' />
            <column datatype='real' name='[Overall Median Losses Qtr]' role='measure' type='quantitative' />
            <column datatype='real' name='[Overall Median Losses Yr]' role='measure' type='quantitative' />
            <column aggregation='Sum' datatype='integer' name='[Quarter]' role='dimension' type='quantitative' />
            <column datatype='string' name='[Report Type]' role='dimension' type='nominal' />
            <column caption='State Name' datatype='string' name='[StateName]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column aggregation='Sum' datatype='integer' name='[Year]' role='dimension' type='quantitative' />
            <column-instance column='[Fraud]' derivation='None' name='[none:Fraud:nk]' pivot='key' type='nominal' />
