      <column caption='Rank-F&amp;O together' datatype='integer' name='[Calculation_2965338889494716428]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([Calculation_2965338889491578890]),&apos;desc&apos;)'>
