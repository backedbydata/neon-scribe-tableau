      <column caption='Fixed Overall Median Yr' datatype='real' name='[Calculation_1102537487927623680]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Year],[Report Type]: MIN([Overall Median Losses Yr])}' />
      </column>
      <column caption='Future data' datatype='boolean' name='[Calculation_1588926284659273728]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Year] &gt; YEAR(TODAY())-1' />
      </column>
      <column caption='State View Selection' datatype='string' name='[Calculation_1597651976229257216]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[MSA View (copy)]' />
      </column>
      <column caption='Make my sheet swap work' datatype='string' name='[Calculation_1597651976230133761]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&apos;&apos;' />
      </column>
      <column caption='Categories Title' datatype='string' name='[Calculation_1597651976233316355]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Top 10 Fraud Report Categories&quot;' />
      </column>
      <column caption='Fraud Facts Title' datatype='string' name='[Calculation_1597651976233603076]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Fraud Facts&quot;' />
      </column>
      <column caption='Rank ' datatype='integer' name='[Calculation_1597651976242204677]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK([Calculation_3843822308786319360])'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='State Footnote' datatype='string' name='[Calculation_1597651976253399046]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IIF([Parameters].[MSA View (copy)] = &apos;Map&apos;,&#13;&#10;&apos;State population estimates are based on U.S. Census population estimates for &apos;+[Parameters].[LPC View (copy)_1344606019964723200]+&apos;. State level data excludes state-specific data contributor reports. Certain Fraud categories are comprised of subcategories that fall in both Fraud and Other report types. The Fraud rankings exclude subcategories that are not fraud.&apos;,&#13;&#10;&apos;The District of Columbia and Puerto Rico are included in the table but are not ranked. State rankings are based on the number of reports per 100,000 population. Population estimates are based on U.S. Census population estimates for &apos;+[Parameters].[LPC View (copy)_1344606019964723200]+&apos;. State level data excludes state-specific data contributor reports.&apos;)' />
      </column>
      <column caption='DC Only' datatype='boolean' name='[Calculation_1834372490994757632]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[StateName] = &apos;District of Columbia&apos;' />
      </column>
      <column caption='Fixed State Qtr Losses' datatype='real' name='[Calculation_2425188443996692503]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [StateName],[Year], [Quarter], [Fraud]: MAX([Total Losses])}' />
      </column>
      <column caption='Fixed Overall Qtr Losses' datatype='real' name='[Calculation_2425188444016369688 1 1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [Year], [Quarter], [Report Type]: Min([Overall Total Losses by Type Qtr])}' />
      </column>
      <column caption='Fixed Overall Qtr Count ' datatype='real' name='[Calculation_2425188444016369688 1]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{FIXED [Year], [Quarter], [Report Type]: Min([Overall # of Reports by Type QTR])}' />
      </column>
      <column caption='Fixed State Type' datatype='real' name='[Calculation_2425188444016369688]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [StateName],[Year], [Quarter], [Fraud]: Min([State Fraud/Other Count])}' />
      </column>
      <column caption='Fixed Overall Median Qtr' datatype='real' name='[Calculation_2425188444313452572 1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Year],[Quarter],[Report Type]: MIN([Overall Median Losses Qtr])}' />
      </column>
      <column caption='Fixed State Median Qtr' datatype='real' name='[Calculation_2425188444313452572]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [Year], [Quarter],[StateName], [Report Type]: min([state_median_quarterly])}' />
      </column>
      <column caption='Fraud Losses Logic' datatype='real' default-format='c&quot;$&quot;#,##0;(&quot;$&quot;#,##0)' name='[Calculation_2425188444315267101 1]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='IIF(TOTAL( COUNTD( [StateName] ) ) = SUM( { FIXED : COUNTD( [StateName] ) } ),SUM([Calculation_2425188444016369688 1 1]),&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;SUM([Calculation_2425188443996692503]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Fraud Reports Logic' datatype='integer' name='[Calculation_2425188444315267101]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='IIF(TOTAL( COUNTD( [StateName] ) ) = SUM( { FIXED : COUNTD( [StateName] ) } ),INT(SUM([Calculation_2425188444016369688 1])),&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;INT(SUM([Calculation_2425188444016369688])))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Rank' datatype='integer' name='[Calculation_2708070818551529472]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_UNIQUE([Calculation_3460171931540054016],&apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Blank' datatype='string' name='[Calculation_2708070818563719169]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&apos;&apos;' />
      </column>
      <column caption='Fixed State Cat F&amp;O together' datatype='real' name='[Calculation_2965338889491578890]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Year], [Quarter], [StateName], [Category] : MIN([Qtr Category Complaint Count Total]) }' />
      </column>
      <column caption='Category Color Logic' datatype='string' name='[Calculation_2965338889494224907]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IIF([Fraud]=&apos;IDT&apos;,&apos;IDT&apos;,&apos;F&amp;O&apos;)' />
      </column>
      <column caption='Rank-F&amp;O cat together' datatype='integer' name='[Calculation_2965338889494716428 1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([Calculation_2965338889491578890]),&apos;desc&apos;)'>
