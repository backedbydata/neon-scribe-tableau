          <datasource-dependencies datasource='federated.1xlz3n2061m65e13vr58o06l9av8'>
            <column caption='Fixed State Cat F&amp;O together' datatype='real' name='[Calculation_2965338889491578890]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [Year], [Quarter], [StateName], [Category] : MIN([Qtr Category Complaint Count Total]) }' />
            </column>
            <column caption='Category Color Logic' datatype='string' name='[Calculation_2965338889494224907]' role='dimension' type='nominal'>
