      </column>
      <column caption='$ State &amp; Age Med Qtr' datatype='real' name='[Calculation_1385419877191495689]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='//$ State &amp; Age Med Qtr&#13;&#10;{ FIXED [StateName],[Year],[Quarter],[Fraud],[Consumer_Age] : MIN([state_median_quarterly age]) }&#13;&#10;' />
      </column>
      <column caption='$ State &amp; Age Med Yr' datatype='real' name='[Calculation_1385419877191524362]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='//$ State &amp; Age Med Yr&#13;&#10;{ FIXED [StateName],[Year],[Quarter],[Fraud],[Consumer_Age] : MIN([state_median_year_age]) }&#13;&#10;' />
      </column>
      <column caption='Median Logic Count 1' datatype='boolean' name='[Calculation_1385419877191569419]' role='measure' type='nominal'>
        <calculation class='tableau' formula='//Median Logic Count 1&#13;&#10;// 4 quarters are selected&#13;&#10;COUNTD([Quarter]) = 4' />
      </column>
      <column caption='Median Logic Count 2' datatype='boolean' name='[Calculation_1385419877191589900]' role='measure' type='nominal'>
        <calculation class='tableau' formula='//Median Logic Count 2&#13;&#10;// all quarters of current year are selected (ie YTD)&#13;&#10;MAX({FIXED : MAX([Year])}) = MAX([Year]) AND MAX({FIXED [Year] : MAX([Quarter])}) = COUNTD([Quarter])' />
      </column>
      <column caption='$ State &amp; Age Ttl Loss' datatype='real' default-format='c&quot;$&quot;#,##0;(&quot;$&quot;#,##0)' name='[Calculation_1385419877191630861]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='//$ State &amp; Age Ttl Loss&#13;&#10;{ FIXED [StateName],[Year],[Quarter],[Fraud],[Consumer_Age] : MIN([Total Losses Age]) }&#13;&#10;' />
      </column>
      <column caption='# State Fraud' datatype='integer' name='[Calculation_1385419877202632719]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [StateName],[Year],[Quarter],[Fraud] : MIN([state_fraud_count]) }' />
      </column>
      <column caption='% with age' datatype='real' default-format='p0.0%' name='[Calculation_1385419877209903122]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1385419877191364615])/SUM([Calculation_1385419877202632719])' />
      </column>
      <column caption='_Instructions' datatype='string' name='[Calculation_1385419877231714324]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&apos;i&apos;' />
      </column>
      <column caption='_countd age' datatype='integer' name='[Calculation_1507298542393667584]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Consumer_Age])' />
      </column>
      <column caption='$ State &amp; PSC' datatype='real' default-format='c&quot;$&quot;#,##0;(&quot;$&quot;#,##0)' name='[Calculation_869476251897118720]' role='measure' type='quantitative'>
