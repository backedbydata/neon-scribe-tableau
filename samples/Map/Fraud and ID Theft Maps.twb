          <formatted-text>
            <run fontcolor='#000000' fontname='Franklin Gothic Demi'><![CDATA[<[federated.1xlz3n2061m65e13vr58o06l9av8].[usr:Title State (copy)_4224939448109551618:nk]>]]></run>
            <run>Æ&#10;</run>
            <run fontname='Franklin Gothic Demi' fontsize='12'><![CDATA[Year: <[federated.1xlz3n2061m65e13vr58o06l9av8].[none:Year:ok]><[federated.1xlz3n2061m65e13vr58o06l9av8].[usr:Title Year (copy):nk]>]]></run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='rtp_ComplaintCountByState' name='federated.1xlz3n2061m65e13vr58o06l9av8' />
          </datasources>
          <datasource-dependencies datasource='federated.1xlz3n2061m65e13vr58o06l9av8'>
            <column aggregation='Sum' datatype='integer' name='[Quarter]' role='dimension' type='quantitative' />
            <column caption='State Name' datatype='string' name='[StateName]' role='dimension' semantic-role='[State].[Name]' type='nominal' />
            <column caption='Title State F&amp;O' datatype='string' name='[Title State (copy)_4224939448109551618]' role='measure' type='nominal'>
              <calculation class='tableau' formula='CASE TOTAL(COUNTD([StateName]))&#13;&#10;  WHEN 52 THEN &apos;All Fraud and Other Reports&apos;&#13;&#10;  WHEN 1 THEN MIN([StateName])&#13;&#10;  ELSE STR(COUNTD([StateName]))+&apos; States Selected&apos;&#13;&#10;  END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Title Quarter' datatype='string' name='[Title Year (copy)]' role='measure' type='nominal'>
              <calculation class='tableau' formula='//If the fixed max year = the max year (2018) AND the fixed max quarter = number of quarters AND there are less than 4  ===== YTD&#13;&#10;IIF(max({fixed: max([Year])}) = max([Year]) AND max({FIXED  [Year]:max([Quarter])}) == countd([Quarter]) AND countd([Quarter])&lt;4,&apos; YTD&apos;,&#13;&#10;&#13;&#10;IIF((COUNTD([Quarter])=4),&apos;&apos;,&#13;&#10;IIF((COUNTD([Quarter])=1 AND str(min([Quarter])) = &apos;1&apos;), &apos;, Quarter: 1&apos;,&#13;&#10;IIF((COUNTD([Quarter])=1 AND str(min([Quarter])) = &apos;2&apos;), &apos;, Quarter: 2&apos;,&#13;&#10;IIF((COUNTD([Quarter])=1 AND str(min([Quarter])) = &apos;3&apos;), &apos;, Quarter: 3&apos;,&#13;&#10;IIF((COUNTD([Quarter])=1 AND str(min([Quarter])) = &apos;4&apos;), &apos;, Quarter: 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;2&apos;), &apos;, Quarters: 1 &amp; 2&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;3&apos;), &apos;, Quarters: 1 &amp; 3&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;4&apos;), &apos;, Quarters: 1 &amp; 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;2&apos; AND str(max([Quarter])) = &apos;3&apos;), &apos;, Quarters: 2 &amp; 3&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;2&apos; AND str(max([Quarter])) = &apos;4&apos;), &apos;, Quarters: 2 &amp; 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=2 AND str(min([Quarter])) = &apos;3&apos; AND str(max([Quarter])) = &apos;4&apos;), &apos;, Quarters: 3 &amp; 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=3 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;3&apos;), &apos;, Quarters: 1, 2, 3&apos;,&#13;&#10;IIF((COUNTD([Quarter])=3 AND str(min([Quarter])) = &apos;2&apos; AND str(max([Quarter])) = &apos;4&apos;), &apos;, Quarters: 2, 3, 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=3 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;4&apos; AND str(median([Quarter])) = &apos;2&apos;), &apos;, Quarters: 1, 2, 4&apos;,&#13;&#10;IIF((COUNTD([Quarter])=3 AND str(min([Quarter])) = &apos;1&apos; AND str(max([Quarter])) = &apos;4&apos; AND str(median([Quarter])) = &apos;3&apos;), &apos;, Quarters: 1, 3, 4&apos;,&#13;&#10;&#13;&#10;&apos;ERROR&apos;))))))))))))))))' />
            </column>
            <column aggregation='Sum' datatype='integer' name='[Year]' role='dimension' type='quantitative' />
            <column-instance column='[Quarter]' derivation='None' name='[none:Quarter:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Year]' derivation='None' name='[none:Year:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Title State (copy)_4224939448109551618]' derivation='User' name='[usr:Title State (copy)_4224939448109551618:nk]' pivot='key' type='nominal'>
              <table-calc ordering-type='Rows' />
            </column-instance>
            <column-instance column='[Title Year (copy)]' derivation='User' name='[usr:Title Year (copy):nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1xlz3n2061m65e13vr58o06l9av8].[Action (State Name) 1]'>
            <groupfilter function='level-members' level='[StateName]' user:ui-action-filter='[Action1]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
          <filter class='categorical' column='[federated.1xlz3n2061m65e13vr58o06l9av8].[none:Quarter:ok]' filter-group='22'>
