        <column caption='Salary Bands' datatype='string' name='[Calculation_159033402293936128]' role='dimension' type='nominal'>
          <calculation class='tableau' formula='IF [AnnualSalary]&lt;50000 THEN &apos;&lt;$50,000&apos;&#10;ELSEIF [AnnualSalary]&lt;75000 THEN &apos;$50,000-$74,999&apos;&#10;ELSEIF [AnnualSalary]&lt;100000 THEN &apos;$75,000-$100,000&apos;&#10;ELSE &apos;$100,000+&apos; END' />
