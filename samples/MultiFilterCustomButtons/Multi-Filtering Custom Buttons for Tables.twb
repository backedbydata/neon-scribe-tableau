      <aliases enabled='yes' />
      <column caption='Absenteeism Rate' datatype='real' name='[AbsenteeismRate]' role='measure' type='quantitative' />
      <column caption='Annual Salary' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[AnnualSalary]' role='measure' type='quantitative' />
      <column caption='True' datatype='boolean' name='[Calculation_104849431753039872]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='TRUE' />
      </column>
      <column caption='False' datatype='boolean' name='[Calculation_104849431753080833]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='FALSE' />
      </column>
      <column caption='Recently Promoted' datatype='string' name='[Calculation_108579012702625792]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IIF([PromotionInLastYear]=1,&apos;Yes&apos;, &apos;No&apos;)' />
      </column>
      <column caption='Employees Tenure&gt;5 and Age &lt;30' datatype='boolean' name='[Calculation_1129559137008394240]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 16]=FALSE OR&#10;&#10;([Parameters].[Parameter 16] AND [Tenure]&gt;5 AND [Age]&lt;30)&#10;&#10;/*&#10;CASE [Employees List: Young with Tenure &gt;10]&#10;WHEN TRUE THEN&#10;    IF [Tenure]&gt;5&#10;    AND [Age]&lt;30&#10;    THEN TRUE ELSE FALSE END&#10;WHEN FALSE THEN TRUE&#10;END&#10;*/' />
      </column>
      <column caption='Salary Bands' datatype='string' name='[Calculation_159033402293936128]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [AnnualSalary]&lt;50000 THEN &apos;&lt;$50,000&apos;&#10;ELSEIF [AnnualSalary]&lt;75000 THEN &apos;$50,000-$74,999&apos;&#10;ELSEIF [AnnualSalary]&lt;100000 THEN &apos;$75,000-$100,000&apos;&#10;ELSE &apos;$100,000+&apos; END' />
      </column>
      <column caption='Employees Low Performance' datatype='boolean' name='[Calculation_421086621054783490]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 17]=FALSE OR&#10;&#10;([Parameters].[Parameter 17] AND [PerformanceRating]&lt;3)&#10;&#10;/*&#10;CASE [Employee List: Performance &lt;3]&#13;&#10;WHEN TRUE THEN&#13;&#10;    IF [Performance Rating]&lt;3&#13;&#10;    THEN TRUE ELSE FALSE END&#13;&#10;WHEN FALSE THEN TRUE&#13;&#10;END&#10;*/' />
      </column>
      <column caption='Max Date' datatype='date' name='[Calculation_421086621068742662]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{MAX(TODAY())}' />
      </column>
      <column caption='Deselect' datatype='string' name='[Calculation_4638003988735442965]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&apos;&apos;&#10;&#10;//used in highlight action to deselect the expand button&#10;//and the incomplete and complete buttons' />
      </column>
      <column caption='Employee ID' datatype='string' name='[EmployeeID]' role='dimension' type='nominal' />
      <column caption='Employees Absent (copy)' datatype='boolean' name='[Employees Absent (copy)_4683743618240409603]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Patient List: No Accountable Visit (copy)_1129559137082429454]&#10;WHEN TRUE THEN FALSE&#10;WHEN FALSE THEN TRUE&#10;END' />
      </column>
      <column caption='Employees Low Performance (copy)' datatype='boolean' name='[Employees Low Performance (copy)_104849431757533186]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 17]&#13;&#10;WHEN TRUE THEN FALSE&#13;&#10;WHEN FALSE THEN TRUE&#13;&#10;END' />
      </column>
      <column caption='Employees No Training (copy)' datatype='boolean' name='[Employees No Training (copy)_4683743618240344066]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Patient List: ED Visits (copy)_1129559137016860677]&#10;WHEN TRUE THEN FALSE&#10;WHEN FALSE THEN TRUE&#10;END' />
      </column>
      <column caption='Employees Promoted Analyst (copy)' datatype='boolean' name='[Employees Promoted from Lower Rank (copy)_104849431758675971]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Patient List: Acute Visits (copy)_1129559137018077191]&#13;&#10;WHEN TRUE THEN FALSE&#13;&#10;WHEN FALSE THEN TRUE&#13;&#10;END' />
      </column>
      <column caption='Employees Tenure&gt;5 and Age &lt;30 (copy)' datatype='boolean' name='[Employees Tenure&gt;10 and Age &lt;35 (copy)_4683743618239602688]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 16]&#10;WHEN TRUE THEN FALSE&#10;WHEN FALSE THEN TRUE&#10;END' />
      </column>
      <column caption='Employees with Salary &gt;$100K (copy)' datatype='boolean' name='[Employees with Salary &gt;$100K (copy)_4683743618240462852]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Patient List: Open Interventions (copy)_421086621059874820]&#10;WHEN TRUE THEN FALSE&#10;WHEN FALSE THEN TRUE&#10;END' />
      </column>
      <column caption='Engagement Score' datatype='real' name='[EngagementScore]' role='measure' type='quantitative' />
      <column caption='Job Satisfaction' datatype='integer' name='[JobSatisfaction]' role='measure' type='quantitative' />
      <column caption='Participation In Training Sessions' datatype='integer' name='[ParticipationInTrainingSessions]' role='measure' type='quantitative' />
      <column caption='Employees Absent' datatype='boolean' name='[Patients no Accountable Visit (copy)_1129559137082482703]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Patient List: No Accountable Visit (copy)_1129559137082429454]&#10;WHEN TRUE THEN&#10;    IF [AbsenteeismRate]&gt;10&#10;    THEN TRUE ELSE FALSE END&#10;WHEN FALSE THEN TRUE&#10;END' />
      </column>
      <column caption='Employees Promoted Analysts' datatype='boolean' name='[Patients with Acute Visit no PCP (copy)_1129559137018146824]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Patient List: Acute Visits (copy)_1129559137018077191]&#13;&#10;WHEN TRUE THEN&#13;&#10;    IF [PromotionInLastYear]=1&#13;&#10;    AND ([Position]=&apos;Senior Analyst&apos; OR [Position]=&apos;Analyst&apos;)&#13;&#10;    THEN TRUE ELSE FALSE END&#13;&#10;WHEN FALSE THEN TRUE&#13;&#10;END' />
