              <calculation class='tableau' formula='&quot;6&quot;' />
              <aliases>
                <alias key='&quot;1&quot;' value='Last 6 months' />
                <alias key='&quot;2&quot;' value='Last 9 Months' />
                <alias key='&quot;3&quot;' value='Last 12 Months' />
                <alias key='&quot;4&quot;' value='Last 18 Months' />
                <alias key='&quot;5&quot;' value='Last 24 Months' />
                <alias key='&quot;6&quot;' value='All Date Range' />
