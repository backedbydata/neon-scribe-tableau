          <datasource-dependencies datasource='federated.038cirw16xc4n91fw80n91r2cvh7'>
            <column caption='18 months' datatype='boolean' name='[12 months (copy)_1153484460157661266]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[order_date] &gt;= DATEADD(&apos;month&apos;, -18, { MAX([order_date]) })' />
            </column>
            <column caption='24 months' datatype='boolean' name='[18 months (copy)_1153484460157808723]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[order_date] &gt;= DATEADD(&apos;month&apos;, -24, { MAX([order_date]) })' />
            </column>
            <column caption='12 months' datatype='boolean' name='[6months (copy) (copy)_1153484460157481041]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[order_date] &gt;= DATEADD(&apos;month&apos;, -12, { MAX([order_date]) })' />
            </column>
            <column caption='9months' datatype='boolean' name='[6months (copy)_1153484460157358160]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[order_date] &gt;= DATEADD(&apos;month&apos;, -9, { MAX([order_date]) })' />
            </column>
            <column caption='All Date' datatype='boolean' name='[9months (copy)_1153484460161036372]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[order_date] = [order_date]' />
            </column>
            <column caption='Sales/Quantity/Order/Customer Measure ' datatype='integer' name='[Calculation_1153484460123185155]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;    WHEN &quot;1&quot; THEN SUM([sales_amount])&#13;&#10;    WHEN &quot;2&quot; THEN SUM([quantity])&#13;&#10;    WHEN &quot;3&quot; THEN COUNTD([order_name])&#13;&#10;    ELSE COUNTD([customer_key])&#13;&#10;END' />
            </column>
            <column caption='% of total  Measure' datatype='real' name='[Calculation_1153484460149792844]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_1153484460123185155] / SUM({[Calculation_1153484460123185155]})' />
            </column>
            <column caption='MIN(-1.0)' datatype='real' name='[Calculation_1153484460151742542]' role='measure' type='quantitative' user:unnamed='Sheet 11 (2)'>
              <calculation class='tableau' formula='MIN(-1.0)' />
            </column>
            <column caption='6months' datatype='boolean' name='[Calculation_1153484460154966095]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[order_date] &gt;= DATEADD(&apos;month&apos;, -6, { MAX([order_date]) })' />
            </column>
            <column caption='Date parameter ' datatype='boolean' name='[Calculation_1153484460161769558]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 3]&#13;&#10;WHEN &quot;1&quot; THEN [Calculation_1153484460154966095]&#13;&#10;WHEN &quot;2&quot; THEN [6months (copy)_1153484460157358160]&#13;&#10;WHEN &quot;3&quot; THEN [6months (copy) (copy)_1153484460157481041]&#13;&#10;WHEN &quot;4&quot; THEN [12 months (copy)_1153484460157661266]&#13;&#10;WHEN &quot;5&quot; THEN [18 months (copy)_1153484460157808723]&#13;&#10;WHEN &quot;6&quot; THEN [9months (copy)_1153484460161036372]&#13;&#10;END' />
