      </column>
      <column caption='Page | Real Label Lt' datatype='string' name='[Page | Real Label (copy)]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2245114789774606353] = 1 AND [Parameters].[Parameter 5] != 1&#10;THEN &quot;1&quot;&#10;ELSEIF [Calculation_2245114789774606353] = ([Parameters].[Parameter 5] - 1)&#10;THEN &quot;-&quot;&#10;ELSEIF [Calculation_2245114789774606353] = ([Parameters].[Parameter 5] + 1)&#10;THEN &quot;+&quot;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Page | Real Label' datatype='string' name='[Page | Show/Hide (copy)]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2245114789774606353] = [Parameters].[Parameter 5]&#10;THEN STR([Parameters].[Parameter 5])&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Page | color' datatype='string' name='[Page | TF (copy)]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2245114789774606353] = 1&#10;THEN &quot;Col3&quot;&#10;ELSEIF [Calculation_2245114789774606353] = [Parameters].[Parameter 5]&#10;THEN &quot;Col1&quot;&#10;ELSE &quot;Col2&quot;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Page | order' datatype='string' name='[Page | color (copy 2)]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2245114789774606353] = 1&#10;THEN &quot;A&quot;&#10;ELSEIF [Calculation_2245114789774606353] = ([Parameters].[Parameter 5] -1)&#10;THEN &quot;B&quot;&#10;ELSEIF [Calculation_2245114789774606353] = [Parameters].[Parameter 5]&#10;THEN &quot;C&quot;&#10;ELSEIF [Calculation_2245114789774606353] = ([Parameters].[Parameter 5] + 1)&#10;THEN &quot;D&quot;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Page  | size' datatype='integer' name='[Page | color (copy)]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='(IF [Calculation_2245114789774606353] = 1&#10;THEN 1&#10;ELSEIF [Calculation_2245114789774606353] = [Parameters].[Parameter 5]&#10;THEN 3&#10;ELSE 1&#10;END)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
